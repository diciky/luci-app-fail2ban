config fail2ban 'config'
	option enabled '1'
	option dbfile '/var/lib/fail2ban/fail2ban.db'
	option logtarget '/var/log/fail2ban.log'
	option syslogsocket 'auto'
	option socket '/var/run/fail2ban/fail2ban.sock'
	option pidfile '/var/run/fail2ban/fail2ban.pid'
	option loglevel 'INFO'
	option ipv6 '0'

configDefaults ' Defaults'
	option usedns 'warn'
	option ignorecommand ''
	option bantime '3600'
	option findtime '600'
	option maxretry '5'
	option bantimeincrement 'false'
	option bantimemaxtime '86400'
	option bantimefactor '2'

configJail ' sshd'
	option enabled 'true'
	option port '38438'
	option protocol 'tcp'
	option filter 'sshd'
	option logpath '/var/log/auth.log'
	option maxretry '5'
	option bantime '86400'
	option findtime '600'
	option action 'iptables-allports'

configAction ' iptables-allports'
	option actionstart 'iptables -N f2b-sshd'
	option actionstop 'iptables -F f2b-sshd'
	option actioncheck 'iptables -n -L f2b-sshd'
	option actionstart 'iptables -I INPUT -p all -j f2b-sshd'
	option actionunban 'iptables -D f2b-sshd -s %s -j ACCEPT'
	option actionban 'iptables -I f2b-sshd -s %s -j REJECT'
